# ============================================================================
# PCMS Frontend Environment Configuration
# Copy to .env (Vite) or .env.local (Next.js) and adjust as needed
# ============================================================================

# API base URL — when developing, point to API Gateway (recommended)
# or directly to a service for debugging
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Alternative: direct service access (bypass gateway, for debugging)
# VITE_API_BASE_URL=http://localhost:8081/api/v1   # user-service
# VITE_API_BASE_URL=http://localhost:8088/api/v1   # order-service
# VITE_API_BASE_URL=http://localhost:8089/api/v1   # payment-service

# Default language for error messages (vi-VN | en-US)
VITE_DEFAULT_LANG=vi-VN

# Enable dev tools (Redux DevTools, React Query DevTools, etc.)
VITE_ENABLE_DEVTOOLS=true

# Correlation ID is auto-generated if not provided (CR-06)
# Frontend can generate one for each user session for traceability:
# import { v4 as uuidv4 } from 'uuid';
# const sessionId = uuidv4();
# VITE_SESSION_CORRELATION_ID=<uuid>
